# Private overrides for the public site config (gitignored).
#
# This file is loaded after _config.js via <script src="_config.private.js">.
# Anything you put here overrides the matching key in window.SITE_CONFIG.
#
# To use this file on the Pi only (NOT pushed to GitHub):
#   1. cp _config.private.js.example _config.private.js
#   2. Edit _config.private.js with the real values
#   3. The site loads it automatically when served from the Pi.
#
# On Cloudflare Pages production, you'll instead set the values as
# environment variables and inject them at build time.

window.SITE_CONFIG = window.SITE_CONFIG || {};
window.SITE_CONFIG.contactEmail = "deflockalamo@proton.me";
